@model IEnumerable<Tund13.Models.Koolitus>
@{
    ViewData["Title"] = "Koolituste haldus";
}

<div class="kk-page-header">
    <div><h1>Koolitused</h1></div>
    <a asp-action="LisaKoolitus" class="btn btn-primary">+ Lisa koolitus</a>
</div>

@if (TempData["Teade"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Teade"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="kk-table">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Kursus</th>
                <th>Õpetaja</th>
                <th>Algus</th>
                <th>Lõpp</th>
                <th>Hind</th>
                <th>Täituvus</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var k in Model)
            {
                int osalejaid = k.Registreerimised.Count(r => r.Staatus != RegistreerimiseStaatus.Tuhistatud);
                bool tais = osalejaid >= k.MaxOsalejaid;
                <tr>
                    <td>
                        @ViewHelpers.KeeleFlag(k.Keelekursus?.Keel ?? "")
                        <span style="font-weight:600">@k.Keelekursus?.Nimetus</span>
                        <span class="@ViewHelpers.TaseBadgeClass(k.Keelekursus?.Tase ?? KursuseTase.A1) ms-1">@k.Keelekursus?.Tase</span>
                    </td>
                    <td>@k.Opetaja?.Nimi</td>
                    <td style="font-size:.84rem">@k.AlgusKuupaev.ToString("dd.MM.yyyy")</td>
                    <td style="font-size:.84rem">@k.LoppKuupaev.ToString("dd.MM.yyyy")</td>
                    <td style="font-size:.84rem">@k.Hind.ToString("0.00") €</td>
                    <td>
                        <span style="font-size:.83rem">@osalejaid/@k.MaxOsalejaid</span>
                        @if (tais) { <span class="kk-status kk-status-cancel ms-1">Täis</span> }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="MuudaKoolitus" asp-route-id="@k.Id" class="btn btn-outline-secondary btn-sm">Muuda</a>
                            <a asp-controller="Admin" asp-action="SaadaEmail" asp-route-koolitusId="@k.Id"
                               class="btn btn-outline-primary btn-sm">Email</a>
                            <form asp-action="KustutaKoolitus" asp-route-id="@k.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Kustuta koolitus?')">Kustuta</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<a asp-action="Index" class="btn btn-outline-secondary mt-3">← Töölaud</a>
