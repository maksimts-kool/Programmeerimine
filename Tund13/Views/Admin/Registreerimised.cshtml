@model IEnumerable<Tund13.Models.Registreerimine>
@{
    ViewData["Title"] = "Registreerimised";
}

<div class="kk-page-header">
    <div><h1>Registreerimised</h1></div>
</div>

@if (TempData["Teade"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Teade"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="kk-table">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Õpilane</th>
                <th>Koolitus</th>
                <th>Registreeritud</th>
                <th>Staatus</th>
                <th>Tegevus</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td style="font-size:.84rem">@r.User?.Email</td>
                    <td>
                        @ViewHelpers.KeeleFlag(r.Koolitus?.Keelekursus?.Keel ?? "")
                        <span style="font-weight:600">@r.Koolitus?.Keelekursus?.Nimetus</span>
                        <br />
                        <small style="color:var(--kk-muted)">@r.Koolitus?.AlgusKuupaev.ToString("dd.MM.yyyy")</small>
                    </td>
                    <td style="font-size:.82rem;color:var(--kk-muted)">@r.RegistreerimiseAeg.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <span class="@ViewHelpers.StaatusBadgeClass(r.Staatus)">@r.Staatus</span>
                    </td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            @if (r.Staatus != RegistreerimiseStaatus.Kinnitatud)
                            {
                                <form asp-action="MuudaStaatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <input type="hidden" name="staatus" value="@RegistreerimiseStaatus.Kinnitatud" />
                                    <button type="submit" class="btn btn-outline-success btn-sm">Kinnita</button>
                                </form>
                            }
                            @if (r.Staatus != RegistreerimiseStaatus.Tuhistatud)
                            {
                                <form asp-action="MuudaStaatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <input type="hidden" name="staatus" value="@RegistreerimiseStaatus.Tuhistatud" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Tühista registreerimine?')">Tühista</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<a asp-action="Index" class="btn btn-outline-secondary mt-3">← Töölaud</a>
