@model Tund13.Models.Koolitus
@{
    ViewData["Title"] = "Lisa koolitus";
}

<h1 class="mb-4">+ Lisa koolitus</h1>

<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body">
        <form asp-action="LisaKoolitus" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="KeelekursusId" class="form-label">Keelekursus</label>
                <select asp-for="KeelekursusId" asp-items="ViewBag.Keelekursused" class="form-select">
                    <option value="">-- Vali kursus --</option>
                </select>
                <span asp-validation-for="KeelekursusId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="OpetajaId" class="form-label">Õpetaja</label>
                <select asp-for="OpetajaId" asp-items="ViewBag.Opetajad" class="form-select">
                    <option value="">-- Vali õpetaja --</option>
                </select>
                <span asp-validation-for="OpetajaId" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="AlgusKuupaev" class="form-label"></label>
                    <input asp-for="AlgusKuupaev" class="form-control" type="date" />
                    <span asp-validation-for="AlgusKuupaev" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LoppKuupaev" class="form-label"></label>
                    <input asp-for="LoppKuupaev" class="form-control" type="date" />
                    <span asp-validation-for="LoppKuupaev" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Hind" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Hind" class="form-control" type="number" step="0.01" min="0" />
                        <span class="input-group-text">€</span>
                    </div>
                    <span asp-validation-for="Hind" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MaxOsalejaid" class="form-label"></label>
                    <input asp-for="MaxOsalejaid" class="form-control" type="number" min="1" max="100" />
                    <span asp-validation-for="MaxOsalejaid" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-info text-white">Salvesta</button>
                <a asp-action="Koolitused" class="btn btn-outline-secondary">Tühista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}