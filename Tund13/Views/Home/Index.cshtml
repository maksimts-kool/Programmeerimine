@{
    ViewData["Title"] = "Keeltekool – Avaleht";
}

<!-- Hero -->
<div class="kk-hero">
    <!-- Decorative SVG geometry -->
    <svg class="kk-hero-deco" width="340" height="340" viewBox="0 0 340 340" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="170" cy="170" r="160" stroke="#2563eb" stroke-width="22"/>
        <circle cx="170" cy="170" r="100" stroke="#2563eb" stroke-width="14"/>
        <circle cx="170" cy="170" r="46"  stroke="#2563eb" stroke-width="8"/>
        <line x1="10"  y1="170" x2="330" y2="170" stroke="#2563eb" stroke-width="6"/>
        <line x1="170" y1="10"  x2="170" y2="330" stroke="#2563eb" stroke-width="6"/>
        <ellipse cx="170" cy="170" rx="70" ry="155" stroke="#2563eb" stroke-width="6"/>
    </svg>

    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="kk-badge-pill">
                <svg width="10" height="10" viewBox="0 0 10 10"><circle cx="5" cy="5" r="5" fill="#2563eb"/></svg>
                Keeltekool — õpi maailma keeli
            </div>
            <h1>Avasta maailm<br/>keelte kaudu</h1>
            <p class="mb-4">Professionaalsed õpetajad, väikesed grupid ja paindlikud koolitusajad. Tasemed A1 kuni C2.</p>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Koolitused" asp-action="Index" class="btn btn-primary btn-lg">Vaata koolitusi</a>
                @if (!User.Identity?.IsAuthenticated == true)
                {
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg">Loo konto</a>
                }
            </div>
        </div>
        <div class="col-lg-5 d-none d-lg-flex justify-content-end">
            <!-- Language globe illustration -->
            <svg width="220" height="220" viewBox="0 0 220 220" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="110" cy="110" r="100" fill="#f1f5f9" stroke="#e2e8f0" stroke-width="2"/>
                <circle cx="110" cy="110" r="70"  fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="4 3"/>
                <circle cx="110" cy="110" r="40"  fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="4 3"/>
                <line x1="10"  y1="110" x2="210" y2="110" stroke="#cbd5e1" stroke-width="1.5"/>
                <line x1="110" y1="10"  x2="110" y2="210" stroke="#cbd5e1" stroke-width="1.5"/>
                <ellipse cx="110" cy="110" rx="46" ry="98" fill="none" stroke="#cbd5e1" stroke-width="1.5"/>
                <!-- Flag pins -->
                <circle cx="80"  cy="76"  r="7" fill="#2563eb"/>
                <circle cx="148" cy="95"  r="7" fill="#16a34a"/>
                <circle cx="68"  cy="138" r="7" fill="#d97706"/>
                <circle cx="152" cy="148" r="7" fill="#dc2626"/>
                <circle cx="110" cy="62"  r="5" fill="#7c3aed"/>
                <text x="80"  y="72"  text-anchor="middle" font-size="8" fill="white" font-weight="bold">EN</text>
                <text x="148" y="91"  text-anchor="middle" font-size="8" fill="white" font-weight="bold">DE</text>
                <text x="68"  y="134" text-anchor="middle" font-size="8" fill="white" font-weight="bold">FR</text>
                <text x="152" y="144" text-anchor="middle" font-size="8" fill="white" font-weight="bold">ES</text>
                <text x="110" y="58"  text-anchor="middle" font-size="7" fill="white" font-weight="bold">FI</text>
            </svg>
        </div>
    </div>
</div>

<!-- Stats strip -->
<div class="kk-stats-strip mb-4">
    <div class="kk-stat">
        <div class="kk-stat-value" style="color:var(--kk-blue)">10+</div>
        <div class="kk-stat-label">Keelt</div>
    </div>
    <div class="kk-stat">
        <div class="kk-stat-value" style="color:var(--kk-green)">6</div>
        <div class="kk-stat-label">Taset (A1–C2)</div>
    </div>
    <div class="kk-stat">
        <div class="kk-stat-value" style="color:var(--kk-amber)">≤10</div>
        <div class="kk-stat-label">Õpilast grupis</div>
    </div>
    <div class="kk-stat">
        <div class="kk-stat-value">100%</div>
        <div class="kk-stat-label">Sertifitseeritud</div>
    </div>
</div>

<!-- Feature tiles -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="kk-tile">
            <div class="kk-tile-icon" style="background:var(--kk-blue-light)">
                <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                </svg>
            </div>
            <h5>Mitmekesine valik</h5>
            <p>Inglise, saksa, prantsuse, soome jt keeled tasemetel A1–C2.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kk-tile">
            <div class="kk-tile-icon" style="background:var(--kk-green-light)">
                <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <h5>Kogenud õpetajad</h5>
            <p>Magistrikraadiga ja sertifitseeritud keeleõpetajad.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kk-tile">
            <div class="kk-tile-icon" style="background:var(--kk-amber-light)">
                <svg viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <h5>Paindlik ajakava</h5>
            <p>Väikesed grupid, isikupärastatud lähenemine ja erinevad kellaajad.</p>
        </div>
    </div>
</div>