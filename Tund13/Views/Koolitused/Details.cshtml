@model Tund13.Models.Koolitus
@{
    ViewData["Title"] = Model.Keelekursus?.Nimetus;
    int osavõtjaid = Model.Registreerimised.Count(r => r.Staatus != RegistreerimiseStaatus.Tuhistatud);
    bool grupiTais = osavõtjaid >= Model.MaxOsalejaid;
    bool onRegistreerunud = ViewBag.OnRegistreerunud == true;
    int protsent = Model.MaxOsalejaid > 0
        ? (int)((double)osavõtjaid / Model.MaxOsalejaid * 100) : 0;
    string fillClass = protsent >= 100 ? "high" : protsent >= 70 ? "medium" : "low";
}

@if (TempData["Teade"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Teade"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Viga"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">@TempData["Viga"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="kk-form-card">
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.2rem">
                <div style="font-size:2.2rem">@ViewHelpers.KeeleFlag(Model.Keelekursus?.Keel ?? "")</div>
                <div>
                    <h1 style="font-size:1.5rem;font-weight:800;letter-spacing:-.03em;margin:0">@Model.Keelekursus?.Nimetus</h1>
                    <div style="display:flex;gap:.5rem;align-items:center;margin-top:.3rem">
                        <span class="@ViewHelpers.TaseBadgeClass(Model.Keelekursus?.Tase ?? KursuseTase.A1)">@Model.Keelekursus?.Tase</span>
                        @if (grupiTais) { <span class="kk-status kk-status-cancel">Grupp täis</span> }
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Keelekursus?.Kirjeldus))
            {
                <p style="color:var(--kk-muted);margin-bottom:1.2rem">@Model.Keelekursus.Kirjeldus</p>
            }
            <div class="kk-meta" style="margin-bottom:1rem">
                <div class="kk-meta-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span><strong style="color:var(--kk-text)">Õpetaja:</strong> @Model.Opetaja?.Nimi</span>
                </div>
                <div class="kk-meta-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span><strong style="color:var(--kk-text)">Algus:</strong> @Model.AlgusKuupaev.ToString("dd. MMMM yyyy")</span>
                </div>
                <div class="kk-meta-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span><strong style="color:var(--kk-text)">Lõpp:</strong> @Model.LoppKuupaev.ToString("dd. MMMM yyyy")</span>
                </div>
                <div class="kk-meta-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    <span><strong style="color:var(--kk-text)">Hind:</strong> <span style="color:var(--kk-green);font-weight:700">@Model.Hind.ToString("0.00") €</span></span>
                </div>
                <div class="kk-meta-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <span><strong style="color:var(--kk-text)">Kohti:</strong> @osavõtjaid / @Model.MaxOsalejaid täidetud</span>
                </div>
            </div>
            <div class="kk-progress" title="@protsent% täis">
                <div class="kk-progress-fill @fillClass" style="width:@protsent%"></div>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary mt-3">← Tagasi nimekirja</a>
    </div>

    <div class="col-lg-4 d-flex flex-column gap-3">
        <div class="kk-form-card text-center">
            @if (!string.IsNullOrEmpty(Model.Opetaja?.FotoPath))
            {
                <img src="/uploads/@Model.Opetaja.FotoPath" class="rounded-circle mb-2"
                     style="width:80px;height:80px;object-fit:cover" alt="Foto" />
            }
            else
            {
                <div style="width:72px;height:72px;border-radius:50%;background:var(--kk-blue-light);display:inline-flex;align-items:center;justify-content:center;margin-bottom:.6rem">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
            }
            <div style="font-weight:700">@Model.Opetaja?.Nimi</div>
            @if (!string.IsNullOrEmpty(Model.Opetaja?.Kvalifikatsioon))
            {
                <div style="font-size:.82rem;color:var(--kk-muted)">@Model.Opetaja.Kvalifikatsioon</div>
            }
        </div>

        <div class="kk-form-card text-center">
            @if (!User.Identity?.IsAuthenticated == true)
            {
                <p style="color:var(--kk-muted);font-size:.88rem">Registreerumiseks logi sisse.</p>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary w-100">Logi sisse</a>
            }
            else if (!User.IsInRole("Opilane"))
            {
                <p style="color:var(--kk-muted);font-size:.83rem">Registreeruda saavad ainult õpilased.</p>
            }
            else if (onRegistreerunud)
            {
                <span class="kk-status kk-status-ok" style="font-size:.9rem">Oled juba registreerunud!</span>
            }
            else if (grupiTais)
            {
                <span class="kk-status kk-status-cancel" style="font-size:.9rem">Grupp on täis.</span>
            }
            else
            {
                <form asp-action="Registreeru" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary w-100">Registreeru koolitusele</button>
                </form>
            }
        </div>
    </div>
</div>
