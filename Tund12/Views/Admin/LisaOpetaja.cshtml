@{
    ViewData["Title"] = "Lisa õpetaja";
}

<h1 class="mb-4">+ Lisa õpetaja</h1>
<p class="text-muted">Süsteem loob automaatselt sisselogimise konto ja seob selle õpetaja profiiliga.</p>

<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body">
        <form asp-action="LisaOpetaja" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <h6 class="text-muted mb-3">👤 Õpetaja profiili andmed</h6>

            <div class="mb-3">
                <label class="form-label" for="nimi">Nimi <span class="text-danger">*</span></label>
                <input type="text" id="nimi" name="nimi" class="form-control" placeholder="nt. Mari Maasikas"
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label" for="kvalifikatsioon">Kvalifikatsioon</label>
                <input type="text" id="kvalifikatsioon" name="kvalifikatsioon" class="form-control"
                       placeholder="nt. Magistrikraad, CELTA sertifikaat" />
            </div>

            <hr />
            <h6 class="text-muted mb-3">🔑 Sisselogimise konto</h6>

            <div class="mb-3">
                <label class="form-label" for="email">E-post <span class="text-danger">*</span></label>
                <input type="email" id="email" name="email" class="form-control"              placeholder="opetaja@kool.ee"
                       required />
            </div>

            <div class="mb-3">
                <label class="form-label" for="parool">Parool <span class="text-danger">*</span></label>
                <input type="password" id="parool" name="parool" class="form-control"
                       placeholder="Vähemalt 8 tähemärki, number ja erimärk" required />
                <div class="form-text">Parool: vähemalt 8 tähemärki, sisaldab numbrit.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Loo õpetaja</button>
                <a asp-action="Opetajad" class="btn btn-outline-secondary">Tühista</a>
            </div>
        </form>
    </div>
</div>

<a asp-action="Index" class="btn btn-outline-secondary mt-3">← Töölaud</a>
