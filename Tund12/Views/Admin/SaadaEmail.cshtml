@{
    ViewData["Title"] = "Saada e-kiri";
    var koolitus = ViewBag.Koolitus as Tund12.Models.Koolitus;
    var opilased = ViewBag.Opilased as List<string>;
}

<h1 class="mb-2">📧 Saada e-kiri õpilastele</h1>
<p class="text-muted mb-4">
    Koolitus: <strong>@koolitus?.Keelekursus?.Nimetus</strong>
    (@koolitus?.AlgusKuupaev.ToString("dd.MM.yyyy"))
</p>

@if (TempData["Teade"] != null)
{
    <div class="alert alert-success">@TempData["Teade"]</div>
}

<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="SaadaEmail" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="koolitusId" value="@koolitus?.Id" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Saajad</label>
                        <div class="border rounded p-2 bg-light small">
                            @if (opilased != null && opilased.Any())
                            {
                                foreach (var e in opilased)
                                {
                                    <span class="badge bg-secondary me-1 mb-1">📧 @e</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Kinnitatud õpilasi pole.</span>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="teema">Teema</label>
                        <input type="text" id="teema" name="teema" class="form-control"
                               placeholder="nt. Tunni toimumise muudatus" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold" for="sisu">Sõnumi sisu</label>
                        <textarea id="sisu" name="sisu" class="form-control" rows="6"
                                  placeholder="Kirjuta siia oma teade…" required></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"                    @(opilased?.Any() == true ? "" : "disabled")>
                            Saada e-kiri (@(opilased?.Count ?? 0) saajale)
                        </button>
                        <a asp-action="Registreerimised" class="btn btn-outline-secondary">Tühista</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="alert alert-info">
            <strong>ℹ️ Info:</strong> E-kiri saadetakse kõigile <em>kinnitatud</em> staatusega õpilastele.
        </div>
    </div>
</div>
