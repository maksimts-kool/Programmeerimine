@{
    ViewData["Title"] = "Admin töölaud";
}

<div class="kk-page-header mb-4">
    <div>
        <h1>Administraatori töölaud</h1>
        <p>Halda kursusi, õpetajaid, koolitusi ja registreerumisi.</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-4">
        <a asp-action="Keelekursused" class="kk-dash-card">
            <div class="kk-dash-icon" style="color:#2563eb">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                </svg>
            </div>
            <div class="kk-dash-value">@ViewBag.KursuseidKokku</div>
            <div class="kk-dash-label">Keelekursused</div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-4">
        <a asp-action="Opetajad" class="kk-dash-card">
            <div class="kk-dash-icon" style="color:#16a34a">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                    <circle cx="9" cy="7" r="4" />
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </svg>
            </div>
            <div class="kk-dash-value">@ViewBag.OpetajaidKokku</div>
            <div class="kk-dash-label">Õpetajad</div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-4">
        <a asp-action="Koolitused" class="kk-dash-card">
            <div class="kk-dash-icon" style="color:#0891b2">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
            </div>
            <div class="kk-dash-value">@ViewBag.KoolitusidKokku</div>
            <div class="kk-dash-label">Koolitused</div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-4">
        <a asp-action="Registreerimised"
               class="kk-dash-card @(ViewBag.OotelRegistreerimised > 0 ? "kk-dash-card--alert" : "")">
            <div class="kk-dash-icon" style="color:#d97706">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
            </div>
            <div class="kk-dash-value">@ViewBag.OotelRegistreerimised</div>
            <div class="kk-dash-label">Ootel registreerumised</div>
        </a>
    </div>
    <div class="col-sm-6 col-lg-4">
        <a asp-action="Registreerimised" class="kk-dash-card">
            <div class="kk-dash-icon" style="color:#64748b">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                    <polyline points="10 9 9 9 8 9" />
                </svg>
            </div>
            <div class="kk-dash-value">@ViewBag.RegistreerimisteKokku</div>
            <div class="kk-dash-label">Registreerumisi kokku</div>
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-auto"><a asp-action="LisaKursus" class="btn btn-primary">+ Lisa keelekursus</a></div>
    <div class="col-auto"><a asp-action="LisaOpetaja" class="btn btn-success">+ Lisa õpetaja</a></div>
    <div class="col-auto"><a asp-action="LisaKoolitus" class="btn btn-info text-white">+ Lisa koolitus</a></div>
</div>
