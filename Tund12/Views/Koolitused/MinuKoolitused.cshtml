@model IEnumerable<Tund12.Models.Registreerimine>
@{
    ViewData["Title"] = "Minu koolitused";
}

<div class="kk-page-header">
    <div>
        <h1>Minu koolitused</h1>
        <p>Sinu aktiivsed ja varasemad registreerumised.</p>
    </div>
</div>

@if (TempData["Teade"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Teade"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Sa ei ole ühelegi koolitusele registreerunud.
        <a asp-action="Index">Vaata koolitusi</a>
    </div>
}
else
{
    <div class="kk-table">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Koolitus</th>
                    <th>Keel / Tase</th>
                    <th>Õpetaja</th>
                    <th>Algus</th>
                    <th>Staatus</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td style="font-weight:600">@r.Koolitus?.Keelekursus?.Nimetus</td>
                        <td>
                            @ViewHelpers.KeeleFlag(r.Koolitus?.Keelekursus?.Keel ?? "")
                            <span class="@ViewHelpers.TaseBadgeClass(r.Koolitus?.Keelekursus?.Tase ?? KursuseTase.A1) ms-1">
                                @r.Koolitus?.Keelekursus?.Tase
                            </span>
                        </td>
                        <td>@r.Koolitus?.Opetaja?.Nimi</td>
                        <td style="font-size:.84rem">@r.Koolitus?.AlgusKuupaev.ToString("dd.MM.yyyy")</td>
                        <td><span class="@ViewHelpers.StaatusBadgeClass(r.Staatus)">@r.Staatus</span></td>
                        <td>
                            @if (r.Staatus != RegistreerimiseStaatus.Tuhistatud)
                            {
                                <form asp-action="TuhistaRegistreerimine" asp-route-id="@r.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Kas oled kindel?')">Tühista</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
