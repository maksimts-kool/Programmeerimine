@model Tund12.Models.Koolitus
@{
    ViewData["Title"] = "Osalejad";
    var kinnitatud = Model.Registreerimised.Where(r => r.Staatus == RegistreerimiseStaatus.Kinnitatud).ToList();
    var ootel = Model.Registreerimised.Where(r => r.Staatus == RegistreerimiseStaatus.Ootel).ToList();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Tagasi</a>
    <div>
        <h1 class="mb-0">
            @ViewHelpers.KeeleFlag(Model.Keelekursus?.Keel ?? "")
            @Model.Keelekursus?.Nimetus
        </h1>
        <small class="text-muted">
            @Model.AlgusKuupaev.ToString("dd.MM.yyyy") – @Model.LoppKuupaev.ToString("dd.MM.yyyy") |
            <span
            class="badge @ViewHelpers.TaseBadgeClass(Model.Keelekursus?.Tase ?? KursuseTase.A1)">@Model.Keelekursus?.Tase</span>
        </small>
    </div>
</div>

<div class="row g-4">
    <!-- Kinnitatud õpilased -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                ✅ Kinnitatud õpilased (@kinnitatud.Count)
            </div>
            <ul class="list-group list-group-flush">
                @if (!kinnitatud.Any())
                {
                    <li class="list-group-item text-muted">Kinnitatud õpilasi pole.</li>
                }
                @foreach (var r in kinnitatud)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>📧 @r.User?.Email</span>
                        <small class="text-muted">@r.RegistreerimiseAeg.ToString("dd.MM.yyyy")</small>
                    </li>
                }
            </ul>
        </div>
    </div>

    <!-- Ootel õpilased -->
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                ⏳ Ootel registreerumised (@ootel.Count)
            </div>
            <ul class="list-group list-group-flush">
                @if (!ootel.Any())
                {
                    <li class="list-group-item text-muted">Ootel registreerumisi pole.</li>
                }
                @foreach (var r in ootel)
                {
                    <li class="list-group-item">
                        📧 @r.User?.Email
                    </li>
                }
            </ul>
        </div>
    </div>
</div>
