@using Microsoft.AspNetCore.Identity
@using Tund12.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="d-flex align-items-center gap-2 kk-nav-auth">
    @if (SignInManager.IsSignedIn(User))
    {
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" style="font-size:.83rem;color:var(--kk-muted)">
            @User.Identity?.Name
        </a>
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn-auth">Logi välja</button>
        </form>
    }
    else
    {
        <a asp-area="Identity" asp-page="/Account/Register" class="btn-auth">Registreeru</a>
        <a asp-area="Identity" asp-page="/Account/Login" class="btn-auth btn-auth-solid">Logi sisse</a>
    }
</div>
