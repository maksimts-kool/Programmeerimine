<!DOCTYPE html>
<html lang="et">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Keelekool</title>
    <!-- Modern Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tund12.styles.css" asp-append-version="true" />
    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #f8f9fa;
        }
        main {
            flex: 1;
        }
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .footer {
            background-color: #343a40;
            color: rgba(255,255,255,.75);
        }
        .footer a {
            color: rgba(255,255,255,.9);
            text-decoration: none;
        }
        .footer a:hover {
            color: #fff;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <header class="sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-globe2 fs-4"></i>
                    <span>Keelekool</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Avaleht</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Trainings" ? "active" : "")" asp-area="" asp-controller="Trainings" asp-action="Index">Koolitused</a>
                        </li>
                        
                        @if (User.IsInRole("Opilane"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Trainings" asp-action="MyTrainings">Minu koolitused</a>
                            </li>
                        }
                        
                        @if (User.IsInRole("Opetaja"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Teacher" asp-action="Dashboard">Töölaud</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock"></i> Haldus
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="adminMenu">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Halduspaneel</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateTeacher"><i class="bi bi-person-plus me-2"></i>Lisa õpetaja</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateCourse"><i class="bi bi-journal-plus me-2"></i>Lisa kursus</a></li>
                                    <li><a class="dropdown-item" asp-controller="Trainings" asp-action="Create"><i class="bi bi-calendar-plus me-2"></i>Lisa koolitus</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Registrations"><i class="bi bi-list-check me-2"></i>Registreeringud</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <div class="d-flex">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container py-5">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="bg-white p-4 p-md-5 rounded shadow-sm">
            @RenderBody()
        </div>
    </main>

    <footer class="footer py-4 mt-auto">
        <div class="container text-center">
            <div class="row gy-3">
                <div class="col-md-4 text-md-start">
                    <h5 class="text-white fw-bold"><i class="bi bi-globe2 me-2"></i>Keelekool</h5>
                    <p class="mb-0 small">Avasta maailm läbi uute keelte.</p>
                </div>
                <div class="col-md-4">
                    <ul class="list-inline mb-0">
                        <li class="list-inline-item"><a href="/" class="small">Avaleht</a></li>
                        <li class="list-inline-item text-muted">&middot;</li>
                        <li class="list-inline-item"><a asp-controller="Home" asp-action="Privacy" class="small">Privaatsus</a></li>
                    </ul>
                </div>
                <div class="col-md-4 text-md-end small">
                    &copy; @DateTime.Now.Year - Keelekooli Infosüsteem
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>